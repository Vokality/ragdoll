{
  "name": "@vokality/ragdoll-extensions",
  "version": "0.1.0",
  "description": "Extension framework for Ragdoll - register tools, handlers, and plugins that integrate with AI agents",
  "type": "module",
  "license": "MIT",
  "author": "Vokality",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vokality/ragdoll.git",
    "directory": "packages/ragdoll-extensions"
  },
  "keywords": [
    "ragdoll",
    "extensions",
    "plugins",
    "mcp",
    "ai",
    "tools",
    "function-calling"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    },
    "./slots": {
      "types": "./dist/slots.d.ts",
      "import": "./dist/slots.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run ../../scripts/run-typescript.ts",
    "dev": "bun run ../../scripts/run-typescript.ts --watch",
    "typecheck": "bun run ../../scripts/run-typescript.ts --noEmit",
    "test": "bun test tests",
    "clean": "bun run ../../scripts/clean.ts dist"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "zod": "catalog:"
  }
}
