{
  "name": "@vokality/ragdoll",
  "version": "0.1.8",
  "description": "An animated character framework with facial expressions, head poses, and themes. Built with React and SVG.",
  "type": "module",
  "license": "MIT",
  "author": "Vokality",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vokality/ragdoll.git",
    "directory": "packages/ragdoll"
  },
  "keywords": [
    "ragdoll",
    "character",
    "animation",
    "facial-expressions",
    "react",
    "svg",
    "avatar",
    "themes"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run ../../scripts/run-typescript.ts",
    "dev": "bun run ../../scripts/run-typescript.ts --watch",
    "typecheck": "bun run ../../scripts/run-typescript.ts --noEmit",
    "clean": "bun run ../../scripts/clean.ts dist",
    "test": "bun test tests/**/*.test.ts"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "typescript": "catalog:"
  }
}
