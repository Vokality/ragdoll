{
  "name": "@vokality/ragdoll-extension-spotify",
  "version": "0.1.0",
  "description": "Spotify playback extension for the Ragdoll framework",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run ../../scripts/run-typescript.ts -p tsconfig.json",
    "dev": "bun run ../../scripts/run-typescript.ts -w -p tsconfig.json",
    "test": "bun test tests",
    "typecheck": "bun run ../../scripts/run-typescript.ts --noEmit -p tsconfig.json",
    "clean": "bun run ../../scripts/clean.ts dist"
  },
  "dependencies": {
    "@vokality/ragdoll-extensions": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "ragdollExtension": {
    "id": "spotify",
    "name": "Spotify",
    "description": "Spotify playback controls with host-local search resolution",
    "capabilities": [
      "tools"
    ],
    "requiredCapabilities": [
      "oauth"
    ],
    "optionalCapabilities": [],
    "entry": "./dist/index.js",
    "canDisable": true,
    "configSchema": {
      "clientId": {
        "type": "string",
        "label": "Spotify Client ID",
        "description": "Create a Spotify Web API app and register http://127.0.0.1:43821/oauth/callback/spotify as its redirect URI",
        "required": true,
        "placeholder": "your-spotify-client-id"
      }
    },
    "oauth": {
      "provider": "spotify",
      "authorizationUrl": "https://accounts.spotify.com/authorize",
      "tokenUrl": "https://accounts.spotify.com/api/token",
      "scopes": [
        "user-read-playback-state",
        "user-modify-playback-state"
      ],
      "clientIdConfigKey": "clientId",
      "callbackPort": 43821,
      "pkce": true
    }
  }
}
