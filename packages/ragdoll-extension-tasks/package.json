{
  "name": "@vokality/ragdoll-extension-tasks",
  "version": "0.1.0",
  "description": "Task management extension for the Ragdoll framework",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run ../../scripts/run-typescript.ts -p tsconfig.json",
    "test": "bun test ./src",
    "dev": "bun run ../../scripts/run-typescript.ts -w -p tsconfig.json",
    "typecheck": "bun run ../../scripts/run-typescript.ts --noEmit -p tsconfig.json",
    "clean": "bun run ../../scripts/clean.ts dist"
  },
  "dependencies": {
    "@vokality/ragdoll-extensions": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "ragdollExtension": {
    "id": "tasks",
    "name": "Task Manager",
    "description": "Task tracking and management tools",
    "capabilities": [
      "tools",
      "stateChannels",
      "slots"
    ],
    "requiredCapabilities": [
      "storage",
      "logger"
    ],
    "optionalCapabilities": [],
    "entry": "./dist/index.js",
    "canDisable": false
  }
}
