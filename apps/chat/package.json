{
  "name": "lumen",
  "version": "0.1.12",
  "private": true,
  "author": "lemuel@vokality.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vokality/ragdoll"
  },
  "homepage": "https://github.com/vokality/ragdoll/tree/main/apps/chat",
  "bugs": {
    "url": "https://github.com/vokality/ragdoll/issues"
  },
  "keywords": [
    "lumen",
    "ragdoll",
    "chat",
    "ai",
    "assistant",
    "animated",
    "character",
    "gpt"
  ],
  "description": "Lumen is an expressive GPT assistant powered by the Ragdoll framework",
  "main": "dist/electron/main.js",
  "type": "module",
  "scripts": {
    "prebuild": "bun run clean",
    "dev": "bun run ../../scripts/run-js-bin.ts vite",
    "build": "bun run ../../scripts/run-typescript.ts && bun run ../../scripts/run-js-bin.ts vite build && bun run build:electron",
    "build:electron": "bun run scripts/build-electron.ts",
    "preview": "bun run ../../scripts/run-js-bin.ts vite preview",
    "electron": "bunx --bun --no-install electron .",
    "electron:dev": "bunx --bun --no-install concurrently -n VITE,ELECTRON -c cyan,yellow \"bun run ../../scripts/run-js-bin.ts vite\" \"bunx --bun --no-install wait-on http://localhost:5173 && bunx --bun --no-install electron .\"",
    "typecheck": "bun run ../../scripts/run-typescript.ts --noEmit && bun run ../../scripts/run-typescript.ts -p tsconfig.electron.json --noEmit && bun run ../../scripts/run-typescript.ts -p tsconfig.preload.json --noEmit",
    "lint": "bun run ../../scripts/run-js-bin.ts oxlint .",
    "test": "bun test src/**/*.test.ts electron/**/*.test.ts",
    "clean": "bun run ../../scripts/clean.ts dist"
  },
  "dependencies": {
    "@vokality/ragdoll": "workspace:*",
    "@vokality/ragdoll-extension-character": "workspace:*",
    "@vokality/ragdoll-extension-pomodoro": "workspace:*",
    "@vokality/ragdoll-extension-spotify": "workspace:*",
    "@vokality/ragdoll-extension-tasks": "workspace:*",
    "@vokality/ragdoll-extension-tic-tac-toe": "workspace:*",
    "@vokality/ragdoll-extensions": "workspace:*",
    "openai": "^6.48.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "semver": "^7.8.5",
    "tar": "^7.5.20",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "26.15.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "wait-on": "^9.0.10"
  }
}
