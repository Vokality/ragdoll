{
  "name": "@example/ragdoll-extension-weather",
  "version": "1.0.0",
  "description": "Example weather extension for Ragdoll - demonstrates how to create extension packages",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": "./package.json"
  },
  "files": [
    "dist"
  ],
  "ragdollExtension": {
    "id": "weather",
    "name": "Weather",
    "description": "Example weather lookup tools",
    "capabilities": [
      "tools"
    ],
    "requiredCapabilities": [],
    "optionalCapabilities": [],
    "entry": "./dist/index.js",
    "canDisable": true,
    "configSchema": {
      "defaultUnits": {
        "type": "select",
        "label": "Default units",
        "options": [
          {
            "label": "Celsius",
            "value": "celsius"
          },
          {
            "label": "Fahrenheit",
            "value": "fahrenheit"
          }
        ],
        "default": "celsius"
      }
    }
  },
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run ../../scripts/run-typescript.ts",
    "dev": "bun run ../../scripts/run-typescript.ts --watch",
    "typecheck": "bun run ../../scripts/run-typescript.ts --noEmit",
    "clean": "bun run ../../scripts/clean.ts dist"
  },
  "dependencies": {
    "@vokality/ragdoll-extensions": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
